# Supabase — get these from your Supabase project settings → API
NEXT_PUBLIC_SUPABASE_URL=https://your-project-ref.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key-here

# PostgreSQL — Supabase connection string (project settings → Database → Connection string)
# Use the "Transaction" pooler URL for serverless deployments (Vercel)
DATABASE_URL=postgresql://postgres.your-project-ref:your-password@aws-0-region.pooler.supabase.com:6543/postgres?pgbouncer=true

# Supabase Service Role — required for admin user invite feature (project settings → API → service_role)
# Keep this secret! Never expose it in the browser.
SUPABASE_SERVICE_ROLE_KEY=

# Resend — optional, for welcome and reminder emails (https://resend.com)
# Leave blank to disable email sending
RESEND_API_KEY=
